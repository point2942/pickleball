# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# JWT
JWT_SECRET=your_random_secret_string_here_min_32_chars

# Admin account (first-time setup)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=yourStrongPassword123

# LINE Notify
LINE_NOTIFY_TOKEN=your_line_notify_token_here

# ECPay (綠界)
ECPAY_MERCHANT_ID=your_merchant_id
ECPAY_HASH_KEY=your_hash_key
ECPAY_HASH_IV=your_hash_iv
ECPAY_API_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckout

# LINE Pay
LINEPAY_CHANNEL_ID=your_linepay_channel_id
LINEPAY_CHANNEL_SECRET=your_linepay_channel_secret
LINEPAY_API_URL=https://sandbox-api-pay.line.me

# App URL (your Render URL after deploy)
APP_URL=https://your-app.onrender.com

PORT=3000
